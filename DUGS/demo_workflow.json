{
  "name": "demo — expressions + branching",
  "nodes": [
    {
      "name": "Start",
      "type": "trigger.manual",
      "params": {"data": {"name": "Alice", "score": 85}}
    },
    {
      "name": "Add Greeting",
      "type": "core.set",
      "params": {
        "mode": "keep",
        "assignments": [
          {"name": "greeting", "value": "Hello {{ $json.name }}!"},
          {"name": "grade", "value": "B"}
        ]
      }
    },
    {
      "name": "Check Score",
      "type": "logic.if",
      "params": {
        "field": "score",
        "operator": "greater or equal",
        "value": "90",
        "type": "number"
      }
    },
    {
      "name": "High Score",
      "type": "core.log",
      "params": {"label": "PASS >=90", "level": "info"}
    },
    {
      "name": "Normal Score",
      "type": "core.log",
      "params": {"label": "BELOW 90", "level": "info"}
    }
  ],
  "connections": {
    "Start":        [{"to": "Add Greeting", "out": 0, "in": 0}],
    "Add Greeting": [{"to": "Check Score",  "out": 0, "in": 0}],
    "Check Score":  [
      {"to": "High Score",   "out": 0, "in": 0},
      {"to": "Normal Score", "out": 1, "in": 0}
    ]
  }
}
