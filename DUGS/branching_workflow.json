{
  "name": "branching demo",
  "nodes": [
    { "name": "Start",     "type": "trigger.manual", "params": { "data": { "temp": 30 } } },
    { "name": "Check Hot", "type": "logic.if",        "params": { "field": "temp", "operator": "greater", "value": 25 } },
    { "name": "Too Hot",   "type": "core.log",        "params": { "label": "HOT branch" } },
    { "name": "Fine",      "type": "core.log",        "params": { "label": "OK branch" } }
  ],
  "connections": {
    "Start":     [{ "to": "Check Hot", "out": 0, "in": 0 }],
    "Check Hot": [
      { "to": "Too Hot", "out": 0, "in": 0 },
      { "to": "Fine",    "out": 1, "in": 0 }
    ]
  }
}
